generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum CourtLevel {
  SUPREME
  DISTRICT
  COUNTY
  FAMILY
  FEDERAL
  MAGISTRATES
  TRIBUNAL
  OTHER
}

enum CourtDayStatus {
  SCHEDULED
  LIVE
  ADJOURNED
  CLOSED
}

enum CourtSessionStatus {
  BEFORE_SITTING
  LIVE
  JUDGE_RISING_SHORT
  AT_LUNCH
  ADJOURNED_PART_HEARD
  FINISHED
}

enum ListItemStatus {
  WAITING
  CALLING
  HEARING
  LET_STAND
  NOT_BEFORE
  STOOD_DOWN
  ADJOURNED
  PART_HEARD
  CONCLUDED
  SETTLED
  REMOVED
}

enum ActorRole {
  REGISTRAR
  SYSTEM
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Court {
  id         String     @id @default(uuid()) @db.Uuid
  name       String
  courtLevel CourtLevel
  location   String
  room       String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  courtDays CourtDay[]

  @@map("courts")
}

model CourtDay {
  id                String             @id @default(uuid()) @db.Uuid
  courtId           String             @db.Uuid
  date              DateTime           @db.Date
  judgeName         String
  registrarName     String
  status            CourtDayStatus     @default(SCHEDULED)
  sessionStatus     CourtSessionStatus @default(BEFORE_SITTING)
  sessionMessage    String?
  roseAt            DateTime?
  expectedResumeAt  DateTime?
  resumedAt         DateTime?
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  court          Court            @relation(fields: [courtId], references: [id])
  listItems      ListItem[]
  courtEvents     CourtEvent[]
  courtDayUpdates CourtDayUpdate[]
  listItemUpdates ListItemUpdate[]

  @@unique([courtId, date])
  @@index([courtId, date])
  @@map("court_days")
}

model ListItem {
  id                       String         @id @default(uuid()) @db.Uuid
  courtDayId               String         @db.Uuid
  queuePosition            Int
  caseName                 String
  caseReference            String
  partiesShort             String?
  status                   ListItemStatus @default(WAITING)
  estimatedDurationMinutes Int?
  predictedStartTime       DateTime?
  predictedEndTime         DateTime?
  actualStartTime          DateTime?
  actualEndTime            DateTime?
  calledAt                 DateTime?
  notBeforeTime            DateTime?
  adjournedUntil           DateTime?
  stoodDownAt              DateTime?
  restoredAt               DateTime?
  directionCode            String?
  outcomeCode              String?
  publicNote               String?
  internalNote             String?
  isPriority               Boolean        @default(false)
  isHiddenFromPublic       Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  courtDay        CourtDay         @relation(fields: [courtDayId], references: [id])
  listItemUpdates ListItemUpdate[]

  @@index([courtDayId, queuePosition])
  @@index([courtDayId, status])
  @@map("list_items")
}

// ─── Canonical Event Store (Locked Spec) ────────────────────────────────────

/// The canonical, append-only event store for CourtCall.
/// State is a projection of these events — never the source of truth on its own.
/// Sequence is strictly monotonic per courtDay with no gaps or duplicates.
model CourtEvent {
  id             String   @id @default(uuid()) @db.Uuid
  courtDayId     String   @db.Uuid
  sequence       Int
  type           String   // Closed set: CASE_STARTED | CASE_COMPLETED | CASE_ADJOURNED | CASE_NOT_BEFORE_SET | CASE_DELAY_ADDED | COURT_ROSE | COURT_RESUMED | UNDO_APPLIED
  payload        Json     @default("{}")
  causedByUserId String?
  causedByRole   ActorRole
  idempotencyKey String?
  createdAt      DateTime @default(now())

  courtDay CourtDay @relation(fields: [courtDayId], references: [id])

  @@unique([courtDayId, sequence])
  @@unique([idempotencyKey])
  @@index([courtDayId, sequence])
  @@map("court_events")
}

/// Server-side idempotency enforcement table.
/// Every mutating request MUST include an Idempotency-Key header.
/// If the key has already been seen, the same response is returned without creating a new event.
model IdempotencyRecord {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @unique
  eventId      String   @db.Uuid
  responseHash String
  createdAt    DateTime @default(now())

  @@map("idempotency_records")
}

// ─── Legacy Audit Logs ──────────────────────────────────────────────────────

/// Append-only audit/event record for court-wide events.
model CourtDayUpdate {
  id               String    @id @default(uuid()) @db.Uuid
  courtDayId       String    @db.Uuid
  eventType        String
  actorUserId      String?
  actorDisplayName String?
  actorRole        ActorRole
  payloadJson      Json      @default("{}")
  createdAt        DateTime  @default(now())

  courtDay CourtDay @relation(fields: [courtDayId], references: [id])

  @@index([courtDayId, createdAt])
  @@map("court_day_updates")
}

/// Append-only audit/event record for list item events.
model ListItemUpdate {
  id               String    @id @default(uuid()) @db.Uuid
  listItemId       String    @db.Uuid
  courtDayId       String    @db.Uuid
  eventType        String
  actorUserId      String?
  actorDisplayName String?
  actorRole        ActorRole
  previousStatus   String?
  newStatus        String?
  payloadJson      Json      @default("{}")
  createdAt        DateTime  @default(now())

  listItem ListItem @relation(fields: [listItemId], references: [id])
  courtDay CourtDay @relation(fields: [courtDayId], references: [id])

  @@index([listItemId, createdAt])
  @@index([courtDayId, createdAt])
  @@map("list_item_updates")
}
